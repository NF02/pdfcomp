#!/usr/bin/env bash

# Funzione per controllare se Ghostscript esiste
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Funzione compressione standard
pdfcomprimer(){
    gs -sDEVICE=pdfwrite -dCompatibilityLevel=1.4 -dPDFSETTINGS="$comp" -dNOPAUSE \
       -dQUIET -dBATCH -sOutputFile="$pdfOut" "$pdfIn"
}

# Funzione compressione automatica (aggiunge _comp)
pdfcomprimerNo(){
    pdfOutAuto=$(echo "$pdfIn" | sed "s/\.pdf$/_comp.pdf/")
    echo "Output automatico: $pdfOutAuto"
    gs -sDEVICE=pdfwrite -dCompatibilityLevel=1.4 -dPDFSETTINGS="$comp" -dNOPAUSE \
       -dQUIET -dBATCH -sOutputFile="$pdfOutAuto" "$pdfIn"
}

# Funzione Preview Interattiva
pdfcomprimerPrev() {
    if [[ -z "$pdfIn" ]]; then
        echo "Errore: file di input mancante!"
        exit 1
    fi

    while true; do
        cat << 'EOF'
 ___________ _____________________________________________________________
|  Quality  | Description                                                 |
|-----------|-------------------------------------------------------------|
| screen    | Output a 72 DPI (massima compressione)                      |
| ebook     | Output a 150 DPI (buon compromesso)                         |
| preprint  | Output a 300 DPI                                            |
| printer   | Output a 300 DPI (alta qualità stampa)                      |
| quit      | Esci dal programma                                          |
 -------------------------------------------------------------------------
EOF
        read -p "Seleziona compressione: " con
        
        [[ "$con" == "quit" ]] && exit 0
        [[ -z "$con" ]] && con="default"

        # Validazione e assegnazione prefisso '/' per Ghostscript
        case $con in
            screen|ebook|preprint|printer|default) comp="/$con" ;;
            *) echo "Formato non valido"; continue ;;
        esac

        echo "Elaborazione preview..."
        gs -sDEVICE=pdfwrite -dCompatibilityLevel=1.4 -dPDFSETTINGS="$comp" -dNOPAUSE \
           -dQUIET -dBATCH -sOutputFile=/tmp/prev.pdf "$pdfIn"

        echo "____________________________________________________________________"
        echo "File Sorgente: $(du -sh "$pdfIn")"
        echo "File Compresso: $(du -sh /tmp/prev.pdf)"
        echo "Livello: $con"
        echo "____________________________________________________________________"
    done
}

# --- Inizio Script ---

if ! command_exists gs; then
    echo "Errore: ghostscript non è installato."
    exit 1
fi

# Default
comp="/default"
pdfIn=""
pdfOut=""

# Gestione Argomenti
case "$1" in
    -h|--help)
        echo "Uso: $0 [opzioni] file_input.pdf [file_output.pdf]"
        echo "-f  (--format): specifica livello (es: -f ebook in.pdf out.pdf)"
        echo "-fl (--format-list): mostra i livelli disponibili"
        echo "-p  (--prev): modalità interattiva"
        exit 0
        ;;
    -fl|--format-list)
        # Mostra tabella (omessa qui per brevità)
        exit 0
        ;;
    -f|--format)
        comp="/$2"
        pdfIn="$3"
        pdfOut="$4"
        ;;
    -p|--prev)
        pdfIn="$2"
        pdfcomprimerPrev
        exit 0
        ;;
    *)
        pdfIn="$1"
        pdfOut="$2"
        ;;
esac

# Verifiche Finali
if [[ -z "$pdfIn" ]]; then
    echo "Errore: file input non specificato. Usa --help per info."
    exit 1
fi

if [[ ! -f "$pdfIn" ]]; then
    echo "Errore: il file '$pdfIn' non esiste."
    exit 1
fi

if [[ "$pdfIn" == "$pdfOut" ]]; then
    echo "Errore: non puoi sovrascrivere il file originale!"
    exit 1
fi

# Esecuzione
if [[ -n "$pdfOut" ]]; then
    pdfcomprimer
else
    pdfcomprimerNo
fi

echo "Operazione completata con successo."
